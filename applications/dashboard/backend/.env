# Application
APP_NAME="Investment Dashboard API"
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/investment_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_DEFAULT_MODEL=claude-sonnet-4-6

# File upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Monitoring
METRICS_ENABLED=true

# First-run admin user seed (set both to create initial admin on first start)
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=Demo@1234
ADMIN_NAME=Administrator

# Portfolio data
# INVESTMENT_EXCEL_SOURCE_PATH = read-only source (mounted from host)
# INVESTMENT_EXCEL_PATH        = writable working copy (auto-created on first refresh)
INVESTMENT_EXCEL_SOURCE_PATH=/app/investment_data/Investment tracking.xlsx
INVESTMENT_EXCEL_PATH=/app/uploads/investment_tracking.xlsx

# Daily email digest
DASHBOARD_URL=https://cornell-chancellor-lets-coordinator.trycloudflare.com
DAILY_EMAIL_ENABLED=true
DAILY_EMAIL_RECIPIENT=chailuck@gmail.com
DAILY_EMAIL_SCHEDULE=30 10 * * 1-5
GMAIL_USER=popchailuck@gmail.com
GMAIL_APP_PASSWORD=hmmw zgpx mlpg wrjv
